{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/webhook/cron/heartbeat",
      "schedule": "* * * * *"
    },
    {
      "path": "/webhook/cron/morning-brief",
      "schedule": "0 2 * * *"
    }
  ]
}
