# Supabase Database Configuration
SUPABASE_URL="yoursupabaseurl"
SUPABASE_KEY="yoursupabasekey"

# Meta WhatsApp Config
WHATSAPP_TOKEN="yourwhatsapptoken"
WHATSAPP_VERIFY_TOKEN="my_super_secret_verify_token_123"
WHATSAPP_APP_SECRET="yourappsecret"

# LLM Config
LLM_PROVIDER="gemini" # or "anthropic"
GEMINI_API_KEY="your_gemini_key"
ANTHROPIC_API_KEY="your_anthropic_key"

# Google Config
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_SHEETS_SERVICE_ACCOUNT_KEY='{"type":"service_account",...}'
GOOGLE_SHEETS_ID="yoursheetsid"

# Server
PORT=3000
